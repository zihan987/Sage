{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sage",
  "version": "1.1.0",
  "identifier": "com.sage.desktop",
  "build": {
    "beforeDevCommand": "cd ui && node ./scripts/dev.mjs",
    "beforeBuildCommand": "cd ui && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Sage",
        "width": 1024,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 768,
        "dragDropEnabled": true,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http: https: data: blob:; media-src 'self' asset: http: https: data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http: https: ws: wss: data: blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "category": "Developer Tools",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "11.0",
      "dmg": {
        "windowSize": {
          "width": 600,
          "height": 400
        },
        "appPosition": {
          "x": 160,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 460,
          "y": 200
        },
        "background": "icons/dmg-background.png"
      }
    },
    "resources": [
      "../../skills",
      "../../../mcp_servers",
      "sidecar",
      "../../wiki"
    ],
    "shortDescription": "",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "deb"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["SimpChinese"],
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.0-37",
          "libgtk-3-0",
          "libglib2.0-0",
          "libssl3",
          "librsvg2-2",
          "libayatana-appindicator3-1 | libappindicator3-1"
        ]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:\\w+)|(tel:\\w+)|(https?://\\S+)|(file://\\S+)|(/[^\\s]+)|([a-zA-Z]:[\\\\/][^\\s]+)).*$"
    },
    "updater": {
      "endpoints": [
        "https://api.zavixai.com/api/system/version/check"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQzk1MzUxMUMwNkI4ODUKUldTRnVBWWNVVlBKNzVSOEFrQWhlcDBySkZHRUVzL1pvaldpWXc5OGU1SytxbC9MWnd1YVhDSG4K"
    }
  }
}
